# ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real values.
# .env* is gitignored (except this example).
# ─────────────────────────────────────────────────────────────

# Supabase — PUBLIC (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — SERVER ONLY. Bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (media storage) — SERVER ONLY
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=onetribe-media
R2_PUBLIC_BASE_URL=        # e.g. https://media.onetribe.dance

# Cloudflare Turnstile (bot gate on write paths)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=            # SERVER ONLY. Unset in dev = verification skipped (fails closed in prod)

# Upload session signing — SERVER ONLY (any long random string)
UPLOAD_SESSION_SECRET=

# Storage driver: "r2" (default when R2 vars are set) or "local" (dev/E2E, no account needed)
STORAGE_DRIVER=

# Translation engine — SERVER ONLY
DEEPL_API_KEY=
# or an LLM provider key if using the hybrid path
# ANTHROPIC_API_KEY=

# Admin — comma-separated operator emails (docs/00 D9 P10). SERVER ONLY.
ADMIN_EMAILS=

# App
NEXT_PUBLIC_SITE_URL=https://onetribe.dance
